# Copy this file to config.yaml before running:
#   cp config.yaml.example config.yaml
# Then edit the values for your environment.
# In Docker Compose this file is mounted at /etc/baskety/config.yaml.

server:
  port: 8080
  public_url: https://baskety.example.com

database:
  url: postgres://baskety:changeme@postgres:5432/baskety

storage:
  backend: local        # local | s3 | azure
  local_path: /data/uploads
  s3:
    endpoint: ""
    bucket: baskety
    access_key: ""
    secret_key: ""
  azure:
    container: ""
    connection_string: ""

encryption:
  key_file: /run/secrets/baskety_key

log:
  level: info
  format: json

ocr:
  provider: tesseract      # "tesseract" (local binary, default) | "http" (docker OCR service)
  endpoint_url: http://ocr:8000   # used when provider=http; set automatically when using --profile easyocr or --profile paddleocr
  bin_path: ""             # path to tesseract binary when provider=tesseract; empty = use $PATH
