#!/usr/bin/env bash
set -euo pipefail

# mise-managed runtimes are not on PATH in hook context — add shims
export PATH="$HOME/.local/share/mise/shims:$PATH"

# ── 1. Block .claude/ from ever being committed ──────────────────────────────
if git diff --cached --name-only | grep -q '^\.claude/'; then
  echo "ERROR: Attempted to commit files under .claude/ — this directory must never be committed."
  echo "       Run: git restore --staged .claude/"
  exit 1
fi

# ── 2. Go: vet + fmt on staged .go files ─────────────────────────────────────
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$GO_FILES" ]; then
  echo "Running go vet..."
  # Collect unique packages containing the staged files
  # Strip the leading "baskety/" prefix — paths are repo-relative but we cd into baskety/ first.
  GO_PKGS=$(echo "$GO_FILES" | xargs -I{} dirname {} | sort -u | sed 's|^baskety/|./|;s|^baskety$|./|' | tr '\n' ' ')
  (cd baskety && go vet $GO_PKGS)

  echo "Checking gofmt..."
  UNFORMATTED=$(echo "$GO_FILES" | xargs gofmt -l 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: The following Go files are not gofmt-formatted:"
    echo "$UNFORMATTED" | sed 's/^/  /'
    echo "       Run: gofmt -w $UNFORMATTED"
    exit 1
  fi
fi

# ── 3. JS/TS: ESLint + Prettier on staged files ───────────────────────────────
JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx|mjs|cjs)$' || true)

if [ -n "$JS_FILES" ]; then
  echo "Running ESLint..."
  pnpm exec eslint --max-warnings=0 $JS_FILES

  echo "Checking Prettier..."
  pnpm exec prettier --check $JS_FILES
fi

exit 0
